# name: test/sql/local/irc_any_catalog/partitioning/test_partitioning_pushdown_bucket.test
# description: Test bucket partition pushdown for multiple types (INTEGER, BIGINT, STRING, DATE, DECIMAL, BINARY, TIMESTAMP)
# group: [partitioning]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

require core_functions

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_external_file_cache=false;

statement ok
CALL enable_logging('HTTP');

#--------------------------------------------------------------------
# INTEGER: bucket(4, value)
# Data: 20 rows, values {10..100 step 10} each appearing twice, plus NULL
# Total: 4 parquet files (one per bucket 0-3)
#--------------------------------------------------------------------

# Clear any logs accumulated during catalog attach / table discovery
statement ok
call truncate_duckdb_logs();

# Read whole table - should open all 4 parquet files
statement ok
select * from my_datalake.default.bucket_partitioned_integer;

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
4

statement ok
call truncate_duckdb_logs();

# Filter by value=10 (bucket 1) - pushdown should open only 1 file
# value=10 appears in rows 1 and 11
query I
select count(*) from my_datalake.default.bucket_partitioned_integer where value = 10;
----
2

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
1

statement ok
call truncate_duckdb_logs();

# Filter by value=90 (bucket 2) - 2 rows (rows 9 and 19), 1 file
query I
select count(*) from my_datalake.default.bucket_partitioned_integer where value = 90;
----
2

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
1

statement ok
call truncate_duckdb_logs();

# IN filter across 2 buckets: value IN (10, 40) -> buckets 1 and 3 -> 2 files
# value=10 -> bucket 1 (rows 1, 11); value=40 -> bucket 3 (rows 4, 14)
query I
select count(*) from my_datalake.default.bucket_partitioned_integer where value IN (10, 40);
----
4

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
2

statement ok
call truncate_duckdb_logs();

# Verify row contents for value=10
query III rowsort
select id, value, name from my_datalake.default.bucket_partitioned_integer where value = 10;
----
1	10	row_1
11	10	row_11

statement ok
call truncate_duckdb_logs();

#--------------------------------------------------------------------
# BIGINT: bucket(8, value)
# Data: values 1T..9T, duplicates for 1T and 2T, plus NULL
# Total: 6 parquet files (distinct occupied buckets)
# Bucket distribution (Spark): 1T->3, 2T->0, 3T->1, 4T->6, 5T->0, 6T->7, 7T->3, 8T->5, 9T->2
# Occupied buckets: 0(2T,5T), 1(3T), 2(9T), 3(1T,7T), 5(8T), 6(4T), 7(6T) = 6 files
# (NULL values stored alongside their bucket file, no separate null file)
#--------------------------------------------------------------------

# Read whole table - 6 files
statement ok
select * from my_datalake.default.bucket_partitioned_bigint;

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
6

statement ok
call truncate_duckdb_logs();

# Filter by value=1000000000000 - 2 rows (rows 1 and 11), 1 file
query I
select count(*) from my_datalake.default.bucket_partitioned_bigint where value = 1000000000000;
----
2

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
1

statement ok
call truncate_duckdb_logs();

# Filter by value=9000000000000 - 1 row, 1 file
query I
select count(*) from my_datalake.default.bucket_partitioned_bigint where value = 9000000000000;
----
1

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
1

statement ok
call truncate_duckdb_logs();

