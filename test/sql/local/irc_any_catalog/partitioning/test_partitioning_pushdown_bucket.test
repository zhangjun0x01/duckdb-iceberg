#--------------------------------------------------------------------
# Extra: IN filter spanning multiple buckets (bucket(4, value))
# value=10, value=20, value=40, value=90 hash to 3 distinct buckets (two values share a bucket)
# value=10 (rows 1,11), value=20 (rows 2,12), value=40 (rows 4,14), value=90 (rows 9,19) = 8 rows
# IN spans 3 distinct files
#--------------------------------------------------------------------

query I
select count(*) from my_datalake.default.bucket_partitioned_integer where value IN (10, 20, 40, 90);
----
8

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
3

statement ok
call truncate_duckdb_logs();

#--------------------------------------------------------------------
# Sparse bucket: bucket(16, value) with only 3 unique values
# This tests the "more buckets than distinct values" scenario:
# 16 buckets configured, but only 2 are occupied
# value=1  -> bucket 14 (rows 1, 4)
# value=2  -> bucket 4  (row 2)
# value=42 -> bucket 4  (rows 3, 5) -- same bucket as value=2
# Result: only 2 parquet files despite 16 configured buckets
#--------------------------------------------------------------------

# Read whole table - only 2 files (14 empty buckets)
statement ok
select * from my_datalake.default.bucket_partitioned_sparse_integer;

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
2

statement ok
call truncate_duckdb_logs();

# Filter value=1 (bucket 14) - 2 rows, 1 file; 15 other buckets pruned
query I
select count(*) from my_datalake.default.bucket_partitioned_sparse_integer where value = 1;
----
2

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
1

statement ok
call truncate_duckdb_logs();

# Filter value=2 (bucket 4) - 1 row, 1 file
query I
select count(*) from my_datalake.default.bucket_partitioned_sparse_integer where value = 2;
----
1

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
1

statement ok
call truncate_duckdb_logs();

# IN filter spanning both occupied buckets: value IN (1, 42) -> buckets 14 and 4 -> 2 files
# value=1 (rows 1,4), value=42 (rows 3,5) = 4 rows
query I
select count(*) from my_datalake.default.bucket_partitioned_sparse_integer where value IN (1, 42);
----
4

query I
select count(distinct request.url) from duckdb_logs_parsed('HTTP') where request.url like '%.parquet';
----
2
