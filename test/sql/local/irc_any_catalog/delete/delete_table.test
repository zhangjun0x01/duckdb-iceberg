# name: test/sql/local/irc_any_catalog/delete/delete_table.test
# description: test integration with iceberg catalog read
# group: [delete]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.test_delete_table;

statement ok
CALL enable_logging('HTTP');

statement ok
set logging_level='debug'

statement ok
create table my_datalake.default.test_delete_table as select range a from range(10);

statement ok
begin;

statement ok
drop table my_datalake.default.test_delete_table;

statement error
select * from my_datalake.default.test_delete_table;
----
<REGEX>:.*does not exist.*

statement ok
abort;

statement ok
select * from my_datalake.default.test_delete_table

statement ok
begin;

statement ok
drop table my_datalake.default.test_delete_table;

statement ok
commit;

statement error
select * from my_datalake.default.test_delete_table;
----
<REGEX>:.*does not exist.*

# purgeRequested defaults to False
query I
SELECT regexp_matches(request.url, 'http://127.0.0.1:.*namespaces/default/tables/test_delete_table\?purgeRequested=false') FROM duckdb_logs_parsed('HTTP') where request.type = 'DELETE';
----
1

statement ok
drop table if exists my_datalake.default.test_delete_table;

statement ok
DETACH my_datalake;
