# name: test/sql/local/irc_custom_setup/attach_options/purge_requested.test
# description: test purge requested attach option
# group: [attach_options]

require-env ICEBERG_SERVER_AVAILABLE

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CREATE SECRET (
    TYPE S3,
    KEY_ID 'admin',
    SECRET 'password',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0
);

statement ok
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    purge_requested True
);

statement ok
call enable_logging('http');

statement ok
create table my_datalake.default.test_purge_table as select range a from range(100);

statement ok
CALL truncate_duckdb_logs()

# purgeRequested = true from attach option.
statement ok
drop table my_datalake.default.test_purge_table;

query I
SELECT request.url FROM duckdb_logs_parsed('HTTP') where request.type = 'DELETE';
----
http://127.0.0.1:8181/v1/namespaces/default/tables/test_purge_table?purgeRequested=true


statement ok
DETACH my_datalake;

statement ok
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    purge_requested false
);

statement ok
create table my_datalake.default.test_purge_table as select range a from range(100);

statement ok
CALL truncate_duckdb_logs()

# purgeRequested = false from attach option.
statement ok
drop table my_datalake.default.test_purge_table;

query I
SELECT request.url FROM duckdb_logs_parsed('HTTP') where request.type = 'DELETE';
----
http://127.0.0.1:8181/v1/namespaces/default/tables/test_purge_table?purgeRequested=false
