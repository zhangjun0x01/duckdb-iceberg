        "test/sql/local/irc_any_catalog/insert/test_transactional_insert_v3.test",
        "test/sql/local/irc_any_catalog/table_properties/test_many_table_properties.test",
        "test/sql/local/irc_any_catalog/test_row_lineage_read.test",
        "test/sql/local/irc_any_catalog/test_row_lineage_write.test",
        "test/sql/local/irc_any_catalog/test_select_row_id.test",
        "test/sql/local/irc_any_catalog/update/test_update_v3_table.test",
        "test/sql/local/irc_any_catalog/delete/test_delete_consolidation_transactional.test",
        "test/sql/local/irc_any_catalog/delete/test_delete_consolidation_commit.test",
        "test/sql/local/irc_any_catalog/update/test_update_deletion_vector_consolidation_commit.test",
        "test/sql/local/irc_any_catalog/test_row_lineage_read_from_upgraded.test",
        "test/sql/local/irc_any_catalog/test_row_lineage_write_after_upgrade.test"
      ]
    },
    {
      "reason": "Requires reparsing url paths in logs or paths in data files",
      "paths": [
        "test/sql/local/irc_any_catalog/iceberg_catalog_eager_refresh.test",
